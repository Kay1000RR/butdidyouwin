---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title: string;
  description: string;
  schema?: any;
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    author?: string;
    section?: string;
    tags?: string[];
  };
}

const { title, description, schema, article } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Generate breadcrumb schema
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbSchema = pathSegments.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://butdidyouwin.com/"
    },
    ...pathSegments.map((segment, i) => ({
      "@type": "ListItem",
      "position": i + 2,
      "name": segment.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' '),
      "item": `https://butdidyouwin.com/${pathSegments.slice(0, i + 1).join('/')}/`
    }))
  ]
} : null;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": "https://butdidyouwin.com/#service",
  "name": "BUT DID YOU WIN",
  "url": "https://butdidyouwin.com/",
  "serviceType": "Paid media audit and paid media diagnosis",
  "telephone": "+17027109325",
  "email": "kay@butdidyouwin.com",
  "areaServed": "US",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Las Vegas",
    "addressRegion": "NV",
    "addressCountry": "US"
  },
  "alternateName": "BDYW",
  "description": "Independent paid media auditor providing forensic audits and optimization services. Flat-fee pricing eliminates conflicts of interest.",
  "logo": "https://butdidyouwin.com/og-image.png",
  "image": "https://butdidyouwin.com/og-image.png",
  "founder": {
    "@type": "Person",
    "name": "Kay Inoue",
    "jobTitle": "Independent Paid Media Auditor",
    "url": "https://butdidyouwin.com/about"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "36.1699",
    "longitude": "-115.1398"
  },
  "priceRange": "$1,250-$8,000",
  "paymentAccepted": ["Cash", "Check", "Credit Card", "Wire Transfer", "ACH"],
  "currenciesAccepted": "USD",
  "slogan": "Verdicts, not pitches.",
  "knowsAbout": [
    "Google Ads",
    "Meta Ads",
    "Facebook Ads",
    "Instagram Ads",
    "PPC Advertising",
    "Conversion Tracking",
    "Attribution Modeling",
    "Marketing Audit",
    "GA4",
    "Google Analytics"
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Paid Media Audit Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Single-Platform Forensic Audit",
          "description": "Independent audit of Google Ads OR Meta Ads with waste quantified in dollars"
        },
        "price": "1250",
        "priceCurrency": "USD"
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Multi-Platform Audit",
          "description": "Comprehensive audit covering Google Ads, Meta Ads, and GA4"
        },
        "priceSpecification": {
          "@type": "PriceSpecification",
          "minPrice": "2500",
          "maxPrice": "3500",
          "priceCurrency": "USD"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Enterprise Audit",
          "description": "Full funnel audit including call tracking, CRM integration, and offline conversions"
        },
        "priceSpecification": {
          "@type": "PriceSpecification",
          "minPrice": "5000",
          "maxPrice": "7500",
          "priceCurrency": "USD"
        }
      }
    ]
  }
};
---

<!doctype html>
<html lang="en" style="scroll-padding-top: 5rem;">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Kay Inoue" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="theme-color" content="#1B3A6D" />
    
    <!-- Geographic -->
    <meta name="geo.region" content="US-NV" />
    <meta name="geo.placename" content="Las Vegas" />
    <meta name="geo.position" content="36.1699;-115.1398" />
    <meta name="ICBM" content="36.1699, -115.1398" />
    
    <!-- Open Graph -->
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="BUT DID YOU WIN - Independent Paid Media Auditor" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="BUT DID YOU WIN" />
    
    {article && (
      <>
        <meta property="article:published_time" content={article.publishedTime} />
        {article.modifiedTime && <meta property="article:modified_time" content={article.modifiedTime} />}
        <meta property="article:author" content={article.author || 'Kay Inoue'} />
        {article.section && <meta property="article:section" content={article.section} />}
        {article.tags?.map(tag => <meta property="article:tag" content={tag} />)}
      </>
    )}
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og-image.png', Astro.site)} />
    <meta name="twitter:image:alt" content="BUT DID YOU WIN - Independent Paid Media Auditor" />
    
    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <!-- RSS Feed for Blog/LinkedIn -->
    <link rel="alternate" type="application/rss+xml" title="BUT DID YOU WIN Blog" href="/rss.xml" />
    
    <!-- Page-Specific Structured Data -->
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
    
    <!-- Breadcrumb Structured Data -->
    {breadcrumbSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    )}
    
    <!-- Organization Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    
    <meta name="generator" content={Astro.generator} />

    <style is:global>
    .article-prose {
      font-size: 1.05rem;
      line-height: 1.8;
      color: #1f2937;
    }

    .article-prose p {
      margin-top: 1.25rem;
    }

    .article-prose > :first-child {
      margin-top: 0;
    }

    .article-prose h2 {
      margin-top: 3.5rem;
      margin-bottom: 0.75rem;
      font-size: 1.45rem;
      line-height: 1.35;
      font-weight: 600;
      color: #0f172a;
    }

    .article-prose h3 {
      margin-top: 2.25rem;
      margin-bottom: 0.5rem;
      font-size: 1.15rem;
      line-height: 1.4;
      font-weight: 600;
      color: #0f172a;
    }

    .article-prose ul,
    .article-prose ol {
      margin-top: 1rem;
      padding-left: 1.25rem;
    }

    .article-prose li {
      margin-top: 0.4rem;
    }

    .article-prose strong {
      font-weight: 600;
      color: #0f172a;
    }

    .article-prose blockquote {
      margin-top: 2.5rem;
      margin-bottom: 2.5rem;
      padding-left: 1rem;
      border-left: 3px solid #1a3a5f;
      color: #374151;
      font-style: italic;
    }

    .article-prose pre {
      margin-top: 1.5rem;
      padding: 1rem;
      overflow-x: auto;
      border-radius: 0.375rem;
      background: #0f172a;
      color: #f9fafb;
    }

    @media (max-width: 640px) {
      .article-prose {
        font-size: 1rem;
        line-height: 1.75;
      }
    }
    </style>

    </head>

  <body class="bg-white text-gray-900 font-sans antialiased">
    <!-- Skip Link for Accessibility -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-white focus:px-4 focus:py-2 focus:rounded focus:shadow-lg focus:text-brand-blue focus:font-semibold">
      Skip to main content
    </a>
    
    <SiteHeader />

    <main id="main-content">
      <slot />
    </main>

    <SiteFooter />
    
    <script src="../scripts/navigation.ts"></script>
  </body>
</html>
