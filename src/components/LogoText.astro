---
interface Props {
  text?: string;
}

const { text = "BUT DID YOU WIN" } = Astro.props;
---

<span class="logo-text" style="font-family: 'Inter', 'Helvetica Neue', Helvetica, Arial, sans-serif; font-weight: 725; color: #1a3a5f; letter-spacing: 0.06em; text-transform: uppercase; font-size: 1.5rem;">
  {text}
</span>
