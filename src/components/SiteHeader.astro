---
import LogoText from './LogoText.astro';
import { NAV_ITEMS, CTA } from '../data/site';

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  const normalized = currentPath.replace(/\/$/, '') || '/';
  const target = href.replace(/\/$/, '') || '/';
  return normalized === target;
}
---

<header class="bg-white border-b border-gray-200 py-5 sticky top-0 z-50">
  <nav
    class="site-container mx-auto px-4 md:px-6 lg:px-8 flex justify-between items-center"
    aria-label="Main navigation"
  >
    <a href="/">
      <LogoText />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex gap-8 text-base items-center">
      {
        NAV_ITEMS.map((item) =>
          item.children ? (
            <li class="relative group">
              <button
                id="services-dropdown-btn"
                class="flex items-center gap-1 hover:text-gray-600 transition-colors"
                aria-expanded="false"
                aria-haspopup="true"
                aria-controls="services-dropdown-menu"
              >
                {item.label}
                <svg
                  class="w-4 h-4 transition-transform"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"
                  />
                </svg>
              </button>
              <ul
                id="services-dropdown-menu"
                class="absolute left-1/2 -translate-x-1/2 top-full mt-2 w-48 bg-white border border-gray-200 rounded-lg shadow-lg opacity-0 invisible transition-all duration-200 z-50"
              >
                {item.children.map((child, ci) => (
                  <li>
                    <a
                      href={child.href}
                      class:list={[
                        'block px-4 py-3 text-sm hover:bg-gray-50 transition-colors',
                        ci < (item.children?.length ?? 0) - 1 && 'border-b border-gray-100',
                      ]}
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          ) : (
            <li>
              <a
                href={item.href}
                class="hover:text-gray-600 transition-colors"
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          )
        )
      }
      <li>
        <a
          href={CTA.primary.href}
          class="inline-block px-6 py-2.5 bg-brand-blue text-white text-sm font-semibold rounded hover:bg-brand-blue-dark transition-colors"
        >
          {CTA.primary.label}
        </a>
      </li>
    </ul>

    <!-- Mobile menu toggle -->
    <button
      id="mobile-menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2 focus:outline-none focus:ring-2 focus:ring-brand-blue rounded"
      aria-label="Toggle mobile menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="block w-6 h-0.5 bg-gray-900 transition-transform" aria-hidden="true"></span>
      <span class="block w-6 h-0.5 bg-gray-900 transition-opacity" aria-hidden="true"></span>
      <span class="block w-6 h-0.5 bg-gray-900 transition-transform" aria-hidden="true"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="hidden md:hidden bg-white border-t border-gray-200"
    aria-label="Mobile navigation"
  >
    <ul class="site-container mx-auto px-4 py-4 space-y-2">
      <li><a href="/" class="block py-2 text-lg hover:text-gray-600 transition-colors">Home</a></li>
      {
        NAV_ITEMS.map((item) =>
          item.children ? (
            <li>
              <span class="block py-2 text-lg font-semibold text-gray-500">{item.label}</span>
              <ul class="pl-6 space-y-2 mt-2">
                {item.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class="block py-2 text-base hover:text-gray-600 transition-colors"
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          ) : (
            <li>
              <a href={item.href} class="block py-2 text-lg hover:text-gray-600 transition-colors">
                {item.label}
              </a>
            </li>
          )
        )
      }
      <li class="pt-4 border-t border-gray-200">
        <a
          href={CTA.primary.href}
          class="block py-3 text-lg font-semibold text-center bg-brand-blue text-white rounded hover:bg-brand-blue-dark transition-colors"
        >
          {CTA.primary.label}
        </a>
      </li>
    </ul>
  </nav>
</header>

<!-- Sticky CTA Bar (Mobile Only) -->
<div
  id="sticky-cta-bar"
  class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 shadow-lg z-40 md:hidden transform translate-y-full transition-transform duration-300"
  role="complementary"
  aria-label="Quick action"
>
  <div class="site-container mx-auto px-4 py-3">
    <a
      href={CTA.primary.href}
      class="block w-full py-3 text-center font-semibold bg-brand-blue text-white rounded hover:bg-brand-blue-dark transition-colors"
    >
      {CTA.primary.label}
    </a>
  </div>
</div>

<style>
  @media (max-width: 767px) {
    body {
      padding-bottom: 80px;
    }
  }
</style>
