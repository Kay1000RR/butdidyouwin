---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Page Not Found | BUT DID YOU WIN"
  description="The page you're looking for doesn't exist. Return to our homepage to learn about independent paid media diagnosis."
>
  <section class="py-24 bg-white">
    <div class="site-container">
      <div class="max-w-2xl mx-auto text-center">
        <div class="mb-8">
          <span class="text-6xl font-mono font-bold text-brand-blue">404</span>
        </div>
        
        <h1 class="text-3xl md:text-4xl font-bold mb-6 text-gray-900">
          Page Not Found
        </h1>
        
        <p class="text-xl text-gray-600 mb-8 leading-relaxed">
          The page you're looking for doesn't exist or has been moved.<br />
          Like misattributed conversions, it simply isn't there.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/" class="btn-primary">
            Return Home
          </a>
          <a href="/contact" class="btn-ghost">
            Request Diagnosis
          </a>
        </div>
        
        <div class="mt-12 pt-8 border-t border-gray-200">
          <p class="text-sm text-gray-500 mb-4">Looking for something specific?</p>
          <ul class="flex flex-wrap justify-center gap-6 text-sm">
            <li><a href="/services" class="text-brand-blue hover:underline">Services & Pricing</a></li>
            <li><a href="/method" class="text-brand-blue hover:underline">Our Method</a></li>
            <li><a href="/about" class="text-brand-blue hover:underline">About Kay</a></li>
            <li><a href="/faq" class="text-brand-blue hover:underline">FAQ</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
