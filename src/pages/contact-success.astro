---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Request Received | BUT DID YOU WIN"
  description="Your audit request has been received. We'll respond within 24 hours."
>
  <section class="py-24 bg-white">
    <div class="site-container">
      <div class="max-w-2xl mx-auto text-center">
        <h1 class="mb-6 text-brand-blue">Request Received</h1>
        
        <div class="prose prose-lg max-w-none">
          <p class="text-xl text-gray-700 mb-8">
            Your audit request has been received.
          </p>
          
          <div class="bg-gray-50 p-8 border-l-4 border-brand-blue text-left mb-12">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">What Happens Next</h3>
            <ol class="space-y-3 text-gray-700">
              <li><strong>Within 24 hours:</strong> You'll receive a response confirming fit and next steps.</li>
              <li><strong>If there's a fit:</strong> We'll schedule a brief call to discuss scope, data access, and timeline.</li>
              <li><strong>After the call:</strong> You'll receive a proposal with fixed pricing and deliverables.</li>
            </ol>
          </div>

          <div class="space-y-4">
            <p>
              <a href="/" class="text-brand-blue hover:underline font-semibold">← Return to homepage</a>
            </p>
            <p class="text-sm text-gray-600">
              If you don't receive a response within 24 hours, check your spam folder or email <a href="mailto:kay@butdidyouwin.com" class="text-brand-blue hover:underline">kay@butdidyouwin.com</a> directly.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
