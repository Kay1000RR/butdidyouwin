---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Paid Media System Diagnosis",
  "provider": {
    "@type": "ProfessionalService",
    "name": "BUT DID YOU WIN",
    "url": "https://butdidyouwin.com",
    "telephone": "+1-702-710-9325",
    "email": "kay@butdidyouwin.com"
  },
  "areaServed": [
    { "@type": "City", "name": "Las Vegas", "containedInPlace": { "@type": "State", "name": "Nevada" } },
    { "@type": "Country", "name": "United States" }
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Paid Media Diagnosis Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Campaign System Diagnosis",
          "description": "Evaluates account structure, tracking integrity, and spend efficiency within a single platform."
        },
        "price": "1250",
        "priceCurrency": "USD",
        "priceValidUntil": "2026-12-31",
        "availability": "https://schema.org/InStock"
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Cross-Channel System Diagnosis",
          "description": "Evaluates how multiple platforms interact, attribute outcomes, and distort reported performance."
        },
        "priceSpecification": {
          "@type": "PriceSpecification",
          "minPrice": "2500",
          "maxPrice": "3500",
          "priceCurrency": "USD"
        },
        "priceValidUntil": "2026-12-31",
        "availability": "https://schema.org/InStock"
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Revenue System Diagnosis",
          "description": "Extends verification into call data and CRM outcomes to confirm whether advertising performance survives downstream reality."
        },
        "priceSpecification": {
          "@type": "PriceSpecification",
          "minPrice": "5000",
          "maxPrice": "7500",
          "priceCurrency": "USD"
        },
        "priceValidUntil": "2026-12-31",
        "availability": "https://schema.org/InStock"
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Post-Diagnosis Execution Support - Essential",
          "description": "Execution support for single-location, single-platform operations. Only available after diagnosis."
        },
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "3000",
          "priceCurrency": "USD",
          "unitCode": "MON",
          "referenceQuantity": {
            "@type": "QuantitativeValue",
            "value": "1",
            "unitCode": "MON"
          }
        },
        "availability": "https://schema.org/InStock"
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Post-Diagnosis Execution Support - Professional",
          "description": "Execution support for multi-location or multi-platform operations. Only available after diagnosis."
        },
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "5000",
          "priceCurrency": "USD",
          "unitCode": "MON",
          "referenceQuantity": {
            "@type": "QuantitativeValue",
            "value": "1",
            "unitCode": "MON"
          }
        },
        "availability": "https://schema.org/InStock"
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Post-Diagnosis Capability Transfer",
          "description": "Complete knowledge transfer, process documentation, and team training for organizations that need internal ownership after inefficiencies are identified."
        },
        "price": "15000",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock"
      }
    ]
  },
  "termsOfService": "Money-back guarantee: if diagnosis doesn't identify at least its fee in inefficiency, full refund provided."
};
---

<BaseLayout 
  title="Services | BUT DID YOU WIN - Paid Media System Diagnosis"
  description="Paid media system diagnosis, post-diagnosis execution support, and capability transfer. Flat-fee pricing, money-back guarantee. Discretion guaranteed."
  schema={schema}
>
  <section class="py-10 md:py-16 bg-white">
    <div class="site-container">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-center mb-4 text-brand-blue">Diagnosis Scopes & Pricing</h1>
        <p class="text-xl text-center text-gray-700 mb-10 leading-relaxed">
          All engagements begin with independent diagnosis. Execution is optional and secondary.
        </p>
      </div>
    </div>
  </section>

  <!-- Paid Media System Diagnosis -->
  <section id="diagnosis" class="py-10 md:py-16 bg-white">
    <div class="site-container">
      <div class="max-w-4xl mx-auto">
        <div class="mb-4">
          <span class="text-sm font-bold text-brand-gray uppercase tracking-wide">Core Offering</span>
        </div>
        <h2 class="mb-6 text-brand-blue">Paid Media System Diagnosis</h2>
        <p class="text-xl italic text-gray-700 mb-8 border-l-4 border-brand-blue pl-6">
          I determine whether paid media performance survives contact with revenue, sales behavior, attribution reality, and economic constraints.
        </p>
        
        <div class="card mb-8">
          <h3 class="text-2xl font-bold mb-6 text-brand-blue">Diagnostic Scopes</h3>
          <div class="space-y-5">
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2 sm:gap-6 border-b pb-4 sm:pb-5">
              <div>
                <div class="font-bold text-base md:text-lg">Campaign System Diagnosis</div>
                <div class="text-sm md:text-base text-gray-600">Evaluates account structure, tracking integrity, and spend efficiency within a single platform (Google or Meta)</div>
              </div>
              <div class="text-xl md:text-2xl font-mono font-bold text-brand-blue whitespace-nowrap">$1,250</div>
            </div>
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2 sm:gap-6 border-b pb-4 sm:pb-5">
              <div class="flex-1">
                <div class="font-bold text-base md:text-lg">Cross-Channel System Diagnosis</div>
                <div class="text-sm md:text-base text-gray-600">Evaluates how multiple platforms interact, attribute outcomes, and distort reported performance (Google + Meta + GA4)</div>
              </div>
              <div class="text-xl md:text-2xl font-mono font-bold text-brand-blue whitespace-nowrap">$2,500–$3,500</div>
            </div>
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2 sm:gap-6">
              <div class="flex-1">
                <div class="font-bold text-base md:text-lg">Revenue System Diagnosis</div>
                <div class="text-sm md:text-base text-gray-600">Extends verification into call data and CRM outcomes to confirm whether advertising performance survives downstream reality</div>
              </div>
              <div class="text-xl md:text-2xl font-mono font-bold text-brand-blue whitespace-nowrap">$5,000–$7,500</div>
            </div>
          </div>
          <p class="text-sm text-gray-600 mt-6 italic">You're buying depth of truth, not platform count.</p>
        </div>

        <div class="card mb-8">
          <h3 class="text-2xl font-bold mb-6 text-brand-blue">What You Receive</h3>
          <p class="text-gray-700 leading-relaxed">
            A written evaluation with waste quantified in dollars. A video walkthrough at executive level, not platform tutorial. A "Do / Stop / Fix First" list ranked by business impact. And a conservative recovery range based on evidence, not hype.
          </p>
        </div>

        <div class="card mb-8">
          <h3 class="text-xl font-bold mb-4 text-brand-blue">Who commissions this work</h3>
          <p class="text-gray-700 leading-relaxed">
            Operators who suspect something's wrong but can't prove it. Founders exposed to payroll when ads underperform. COOs and VPs of Marketing who need performance data that survives board review. CFOs before budget reallocation decisions. The pressure is always the same: are we getting business outcomes or just dashboard activity?
          </p>
        </div>
        
        <div class="bg-brand-blue text-white p-6 rounded-lg">
          <div class="font-bold text-sm uppercase tracking-wide mb-2" style="color: #C0C5CE;">Hard Rule: Money-Back Guarantee</div>
          <p class="text-lg">If the diagnosis does not identify at least its fee in actionable inefficiency, the engagement is refunded in full.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Post-Diagnosis Execution Support -->
  <section id="execution" class="py-10 md:py-16 bg-white">
    <div class="site-container">
      <div class="max-w-4xl mx-auto">
        <div class="mb-4">
          <span class="text-sm font-bold text-brand-gray uppercase tracking-wide">Post-Diagnosis Only</span>
        </div>
        <h2 class="mb-6 text-brand-blue">Post-Diagnosis Execution Support (Optional)</h2>
        <p class="text-lg text-gray-700 mb-8 leading-relaxed" style="padding-left: 1rem; border-left: 4px solid #1a3a5f;">
          Execution support is only available after diagnosis and only when structural corrections are required. This is not an agency relationship. It is implementation of what the diagnosis exposed.
        </p>
        
        <div class="card mb-8">
          <h3 class="text-2xl font-bold mb-6 text-brand-blue">Pricing</h3>
          <div class="space-y-5">
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2 sm:gap-6 border-b pb-4 sm:pb-5">
              <div>
                <div class="font-bold text-base md:text-lg">Foundational</div>
                <div class="text-sm md:text-base text-gray-600">Single-platform, single-location</div>
              </div>
              <div class="text-xl md:text-2xl font-mono font-bold text-brand-blue whitespace-nowrap">$3,000/mo</div>
            </div>
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2 sm:gap-6 border-b pb-4 sm:pb-5">
              <div>
                <div class="font-bold text-base md:text-lg">Professional</div>
                <div class="text-sm md:text-base text-gray-600">Multi-location or multi-platform</div>
              </div>
              <div class="text-xl md:text-2xl font-mono font-bold text-brand-blue whitespace-nowrap">$5,000/mo</div>
            </div>
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2 sm:gap-6">
              <div>
                <div class="font-bold text-base md:text-lg">Enterprise</div>
                <div class="text-sm md:text-base text-gray-600">High-complexity, multiple channels</div>
              </div>
              <div class="text-xl md:text-2xl font-mono font-bold text-brand-blue whitespace-nowrap">$7,500–$8,000/mo</div>
            </div>
          </div>
        </div>
        
        <div class="card">
          <h3 class="text-xl font-bold mb-4 text-brand-blue">Who commissions this work</h3>
          <p class="text-gray-700 leading-relaxed">
            Teams who know what's wrong and need execution without agency conflicts. Multi-location operators who can't afford attribution errors. The question after diagnosis: fix internally, fire the agency, or bring in independent execution?
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Capability Transfer -->
  <section id="capability" class="py-10 md:py-16 bg-white">
    <div class="site-container">
      <div class="max-w-4xl mx-auto">
        <div class="mb-4">
          <span class="text-sm font-bold text-brand-gray uppercase tracking-wide">Post-Diagnosis</span>
        </div>
        <h2 class="mb-6 text-brand-blue">Post-Diagnosis Capability Transfer</h2>
        <p class="text-lg text-gray-700 mb-8 leading-relaxed" style="padding-left: 1rem; border-left: 4px solid #1a3a5f;">
          Designed for organizations that need internal ownership after inefficiencies are identified. The goal is to build your capability, not create dependency.
        </p>
        
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 items-stretch mb-8">
          <div class="card flex flex-col h-full">
            <h3 class="text-xl font-bold mb-3 text-brand-blue">In-Housing Transition</h3>
            <p class="text-gray-700 mb-4 flex-grow">Complete knowledge transfer, process documentation, and team training</p>
            <div class="text-2xl font-mono font-bold text-brand-blue">$15,000</div>
          </div>
          <div class="card flex flex-col h-full">
            <h3 class="text-xl font-bold mb-3 text-brand-blue">Team Training</h3>
            <p class="text-gray-700 mb-4 flex-grow">Hands-on workshop covering platform fundamentals and operational discipline</p>
            <div class="text-2xl font-mono font-bold text-brand-blue">$5,000</div>
          </div>
          <div class="card flex flex-col h-full">
            <h3 class="text-xl font-bold mb-3 text-brand-blue">Ongoing Advisory</h3>
            <p class="text-gray-700 mb-4 flex-grow">Strategic guidance for in-house teams (used sparingly)</p>
            <div class="text-2xl font-mono font-bold text-brand-blue">$250/hr</div>
          </div>
        </div>
        
        <div class="card mb-8">
          <h3 class="text-xl font-bold mb-4 text-brand-blue">Who commissions this work</h3>
          <p class="text-gray-700 leading-relaxed">
            Leaders who want to own the capability, not rent it. The question: do we control this or stay dependent? In-housing isn't always appropriate. When it is, we build the capability and step back.
          </p>
        </div>

        <div class="bg-brand-blue text-white p-6 rounded-lg">
          <div class="font-bold text-sm uppercase tracking-wide mb-2" style="color: #C0C5CE;">Key Differentiator</div>
          <p class="text-lg mb-3"><strong>My objective is to build your internal capability, even when that reduces or eliminates the need for ongoing support.</strong></p>
          <p style="color: #E5E7EB;">Capability transfer is designed to preserve control, ownership, and decision integrity. No vendor lock-in. No manufactured dependency.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-brand-blue text-white">
    <div class="site-container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="mb-6" style="color: #FFFFFF;">Start with Diagnosis</h2>
        <p class="text-xl mb-8" style="color: #E5E7EB;">
          Request a diagnosis. No sales call. No agency pitch.
        </p>
        <a href="/contact" class="btn-inverse inline-block">Request Diagnosis</a>
      </div>
    </div>
  </section>
</BaseLayout>
