---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "mainEntity": {
    "@type": "Person",
    "name": "Kay Inoue",
    "jobTitle": "Independent Paid Media Diagnostician",
    "description": "Independent paid media diagnostician with 25+ years of experience building companies and diagnosing marketing waste. Evaluates paid media systems based on business outcomes, not dashboard metrics.",
    "url": "https://butdidyouwin.com/about",
    "image": "https://butdidyouwin.com/kay-inoue-headshot.jpg",
    "sameAs": [
      "https://www.linkedin.com/in/kayinoue"
    ],
    "worksFor": {
      "@type": "ProfessionalService",
      "name": "BUT DID YOU WIN",
      "url": "https://butdidyouwin.com"
    },
    "knowsAbout": [
      "Paid Media Auditing",
      "Google Ads",
      "Meta Ads",
      "Facebook Advertising",
      "PPC Optimization",
      "Conversion Tracking",
      "Attribution Modeling",
      "Business Operations",
      "Sales Systems",
      "Capital Allocation",
      "Marketing Accountability"
    ],
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Las Vegas",
      "addressRegion": "NV",
      "addressCountry": "US"
    },
    "alumniOf": [],
    "award": [
      "Google Ads Certified",
      "Meta Blueprint Certified",
      "Google Analytics Certified"
    ]
  }
};
---

<BaseLayout 
  title="About | BUT DID YOU WIN - Kay Inoue"
  description="Kay Inoue: Independent paid media diagnostician with 25+ years of business operations experience. Accountable for revenue, payroll, and outcomes. Not just performance metrics."
  schema={schema}
>
  <section class="py-10 md:py-16 bg-white">
    <div class="site-container">
      <div class="max-w-4xl mx-auto">
        <h1 class="mb-6 text-brand-blue text-center">About</h1>
        
        <div>
          
          <!-- Opening Statement with Headshot Adjacent -->
          <div class="mb-8 md:mb-12">
            <p class="text-xl font-bold mb-6 text-center" class="text-gray-900">
              I have been accountable for revenue, payroll, and outcomes.<br />
              Not just performance metrics.
            </p>
            
            <!-- Two-Column Layout: Headshot + Paragraph -->
            <div class="grid md:grid-cols-[280px_1fr] gap-6 md:gap-8 mb-8 md:items-start">
              <!-- Headshot Column -->
              <div class="mx-auto md:mx-0 max-w-[280px] md:max-w-none">
                <img 
                  src="/kay-inoue-headshot.jpg" 
                  alt="Kay Inoue - Independent Paid Media Diagnostician" 
                  class="w-full mb-3 block"
                  width="280"
                  height="350"
                  loading="lazy"
                  decoding="async"
                />
                <div class="border-t border-gray-300 pt-3">
                  <div class="text-xs font-bold uppercase tracking-wider" class="text-gray-500 tracking-widest">KAY INOUE</div>
                  <div class="text-xs" class="text-gray-400 mt-1">Founder & Principal</div>
                </div>
              </div>
              
              <!-- Paragraph Column -->
              <div class="prose prose-base md:prose-lg max-w-none [&>p:first-child]:mt-0">
                <p>
                  I've built and operated businesses across automotive, manufacturing, and commercial services. Founded companies. Negotiated distribution deals. Led revenue teams. Sat inside operations, inventory, fulfillment, and finance. Hit quarterly targets. Missed quarterly targets. Watched the gap between reported performance and actual revenue.
                </p>
                <p>
                  I've also watched months of payroll evaporate because a "successful" campaign drove leads that couldn't close. That experience shapes how I evaluate advertising. I don't assess performance through platform reports. I assess whether spend translated into revenue.
                </p>
                <p>
                  I recognize waste because I've seen it destroy real operations. I distinguish between marketing theater and discipline because I've been accountable for both.
                </p>
              </div>
            </div>
          </div>

          <!-- What I Do -->
          <div class="mb-8 md:mb-12">
            <h2 class="text-brand-blue mb-4 md:mb-6">What I Do</h2>
            <p>
              I diagnose paid media as a business system with downstream consequences. I don't stop at the dashboard metrics you are shown. I evaluate whether advertising made the business materially better.
            </p>
            <p class="mb-6">
              This work is forensic. I examine:
            </p>
            <ul class="mt-0 space-y-2 ml-6 list-disc mb-6">
              <li>Account structure and whether it supports operational control or conceals waste</li>
              <li>Incentive misalignment between platforms, agencies, and business outcomes</li>
              <li>Offer and funnel integrity (whether traffic matches what is actually being sold)</li>
              <li>Lead quality and what sales teams actually receive</li>
              <li>Capital allocation decisions and where spending persists by default rather than evidence</li>
            </ul>
            <p>
              If something worked, I explain why. If it failed, I identify where and how. I don't protect prior decisions.
            </p>
          </div>

          <!-- Why I Am Independent -->
          <div class="mb-8 md:mb-12">
            <h2 class="text-brand-blue mb-4 md:mb-6">Why I Am Independent</h2>
            <div class="bg-gray-50 p-6 rounded-lg mb-6">
              <p class="text-lg mb-4">
                I do not sell media.<br />
                I do not earn based on spend.<br />
                I do not benefit from continued complexity.
              </p>
              <p class="text-lg font-bold" class="text-brand-blue">
                My role exists precisely where incentives break down.
              </p>
            </div>
            <p class="mb-6">
              Agencies are compensated when spend increases. Platforms optimize for their own revenue. Freelancers need recurring engagements to survive. Each model creates predictable distortions. 
            </p>
            <p>
              I'm paid a flat fee to determine what actually happened. My only incentive is accuracy.
            </p>
          </div>

          <!-- Discretion -->
          <div class="mb-8 md:mb-12">
            <h2 class="text-brand-blue mb-4 md:mb-6">Discretion</h2>
            <p class="mb-6">
              Confidentiality isn't a courtesy. It's a requirement.
            </p>
            <p>
              No public reviews. No testimonials. NDAs are standard. Your business intelligence stays private.
            </p>
          </div>

          <!-- What This Isn't -->
          <div class="mb-8 md:mb-12">
            <h2 class="text-brand-blue mb-4 md:mb-6">What This Isn't</h2>
            <p class="mb-6">
              I'm not a growth agency.<br>
              I'm not a creative studio.<br>
              I don't provide brand strategy or manage social media.
            </p>
            <p class="mb-6">
              I diagnose paid media systems and deliver verdicts on performance.
            </p>
            <p class="mb-6">
              If you want validation of existing decisions, this won't be a fit.
            </p>
            <p>
              If you want clarity (including uncomfortable clarity) this is designed for that.
            </p>
          </div>

          <!-- Structured Next Steps CTA -->
          <div class="bg-gray-50 p-6 md:p-8 rounded-r-lg border-l-4 border-brand-blue">
            <h3 class="text-2xl font-bold mb-4" class="text-brand-blue">Next Steps</h3>
            <ul class="space-y-3 mb-6">
              <li class="flex items-start">
                <span class="text-brand-blue mr-3 font-bold">→</span>
                <span><a href="/method" class="text-brand-blue hover:underline font-semibold">See how diagnosis is conducted</a></span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-blue mr-3 font-bold">→</span>
                <span><a href="/fit" class="text-brand-blue hover:underline font-semibold">Confirm whether this is a fit</a></span>
              </li>
              <li class="flex items-start">
                <span class="text-brand-blue mr-3 font-bold">→</span>
                <span><a href="/contact" class="text-brand-blue hover:underline font-semibold">Request a diagnosis</a></span>
              </li>
            </ul>
          </div>

        </div>
      </div>
    </div>
  </section>
</BaseLayout>
