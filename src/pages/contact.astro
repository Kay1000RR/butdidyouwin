---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "mainEntity": {
    "@type": "ProfessionalService",
    "name": "BUT DID YOU WIN",
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "Customer Service",
      "areaServed": "US",
      "availableLanguage": "English"
    }
  }
};
---

<BaseLayout 
  title="Contact Us | BUT DID YOU WIN - Request Paid Media Diagnosis"
  description="Request a forensic paid media diagnosis or discuss evaluation services. Independent judgment with money-back guarantee."
  schema={schema}
>
  <section class="py-10 md:py-16 bg-white">
    <div class="site-container">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-center mb-4 md:mb-6 text-brand-blue">Request a Diagnosis</h1>

        <p class="text-lg md:text-xl text-center text-gray-700 mb-3 md:mb-4 leading-relaxed">
          This form helps determine fit and scope before we schedule a call.
        </p>

        <!-- HubSpot form mount point -->
        <div id="hubspot-contact-form"></div>

        <script is:inline>
          (function () {
            var script = document.createElement("script");
            script.src = "https://js.hsforms.net/forms/embed/v2.js";
            script.async = true;

            script.onload = function () {
              if (window.hbspt) {
                window.hbspt.forms.create({
                  region: "na2",
                  portalId: "245098442",
                  formId: "44ac1cf6-48ed-4783-9956-01b43cd4a3f0",
                  target: "#hubspot-contact-form"
                });
              }
            };

            document.body.appendChild(script);
          })();
        </script>


      </div>
    </div>
  </section>

  <section class="py-10 md:py-16 bg-gray-50">
    <div class="site-container">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="mb-4 md:mb-6 text-brand-blue">Direct Contact</h2>

        <div class="space-y-3 md:space-y-4 text-base md:text-lg text-gray-700">
          <p>
            <strong class="block sm:inline">Phone:</strong>
            <a href="tel:+17027109325" class="text-brand-blue hover:underline">
              (702) 710-9325
            </a>
          </p>

          <p>
            <strong class="block sm:inline">Email:</strong>
            <a href="mailto:kay@butdidyouwin.com" class="text-brand-blue hover:underline break-all sm:break-normal">
              kay@butdidyouwin.com
            </a>
          </p>

          <p>
            <strong class="block sm:inline">Location:</strong>
            <span>Las Vegas, Nevada</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- HubSpot form mobile overrides -->
  <style is:global>
    /* Ensure HubSpot form inputs don't zoom on iOS */
    .hs-form-frame input,
    .hs-form-frame select,
    .hs-form-frame textarea {
      font-size: 16px !important;
    }
    
    /* Tighten HubSpot form spacing on mobile */
    @media (max-width: 639px) {
      .hs-form-frame .hs-form-field {
        margin-bottom: 1rem;
      }
      
      .hs-form-frame .hs-input {
        padding: 0.625rem 0.75rem;
      }
      
      .hs-form-frame .hs-button {
        width: 100%;
        padding: 0.875rem 1.5rem;
      }
    }
  </style>
</BaseLayout>
