---
import BaseLayout from '../../layouts/BaseLayout.astro';

const blogPosts = [
  {
    title: "5 Signs You Need Fresh Eyes on Your Paid Media",
    slug: "5-signs-fresh-eyes-needed",
    description: "When internal teams and agencies become too close to campaigns, critical inefficiencies go unnoticed. Here are five indicators that independent evaluation is overdue.",
    date: "2025-01-15"
  },
  {
    title: "The Cost of Wasted Ad Spend",
    slug: "cost-of-wasted-ad-spend",
    description: "Quantifying the real business impact of inefficient paid media campaigns and why dashboard metrics often mask underlying problems.",
    date: "2025-01-10"
  },
  {
    title: "Why Percentage Pricing Creates Conflicts",
    slug: "percentage-pricing-conflicts",
    description: "How percentage-of-spend agency pricing models create incentive misalignment and why flat-fee structures better serve client interests.",
    date: "2025-01-05"
  }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "BUT DID YOU WIN Blog",
  "description": "Independent insights on paid media auditing, diagnosis, and optimization",
  "url": "https://butdidyouwin.com/blog",
  "publisher": {
    "@type": "Organization",
    "name": "BUT DID YOU WIN",
    "url": "https://butdidyouwin.com"
  }
};
---

<BaseLayout 
  title="Blog | BUT DID YOU WIN - Paid Media Insights"
  description="Independent insights on paid media auditing, diagnosis, and optimization. Learn about forensic evaluation methods and flat-fee pricing models."
  schema={schema}
>
  <section class="py-10 md:py-16 bg-white">
    <div class="site-container">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-center mb-6 text-brand-blue">Blog</h1>
        <p class="text-xl text-center text-gray-700 mb-12 leading-relaxed">
          Independent insights on paid media diagnosis and evaluation
        </p>

        <div class="space-y-8">
          {blogPosts.map(post => (
            <article class="card">
              <time class="text-sm text-gray-500" datetime={post.date}>
                {new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h2 class="text-2xl font-bold text-brand-blue mt-2 mb-3">
                <a href={`/blog/${post.slug}`} class="hover:underline">
                  {post.title}
                </a>
              </h2>
              <p class="text-gray-700 leading-relaxed mb-4">
                {post.description}
              </p>
              <a href={`/blog/${post.slug}`} class="text-brand-blue font-semibold hover:underline">
                Read more →
              </a>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
