---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((p) => p.data.draft !== true)
  .sort(
    (a, b) =>
      new Date(b.data.pubDate).getTime() -
      new Date(a.data.pubDate).getTime()
  );
---

<BaseLayout
  title="Blog | BUT DID YOU WIN"
  description="Independent forensic writing on paid media, attribution, and capital allocation."
>

<section class="site-container py-16">

  <!-- Page header -->
  <header class="mx-auto mb-20 max-w-[720px]">

    <h1 class="text-4xl md:text-5xl font-semibold leading-tight text-gray-900">
      FIELD NOTES
    </h1>

    <p class="mt-5 text-lg text-gray-700 leading-relaxed">
      Independent forensic writing on paid media, attribution, and capital allocation
      for executives and operators responsible for revenue and margin.
    </p>

  </header>

  <!-- Article list -->
  <div class="mx-auto max-w-[720px] space-y-16">

    {posts.map((post) => {
      const words = post.body?.split(/\s+/g).length ?? 0;
      const readTime = Math.max(1, Math.ceil(words / 200));

      const formattedDate = new Date(post.data.pubDate).toLocaleDateString(
        "en-US",
        { year: "numeric", month: "long", day: "numeric" }
      );

      return (
        <article>
          <a href={`/blog/${post.slug}`} class="block group">

            <h2 class="text-2xl md:text-3xl font-semibold leading-snug text-gray-900 group-hover:underline">
              {post.data.title}
            </h2>

            {post.data.description && (
              <p class="mt-3 text-gray-700 leading-relaxed">
                {post.data.description}
              </p>
            )}

            <div class="mt-4 flex flex-wrap gap-x-4 gap-y-1 text-sm text-gray-500">

              <span class="font-medium text-gray-700">
                {post.data.author ?? "Kay Inoue"}
              </span>

              <span aria-hidden="true">•</span>

              <time datetime={post.data.pubDate}>
                {formattedDate}
              </time>

              <span aria-hidden="true">•</span>

              <span>
                {readTime} min read
              </span>

            </div>

          </a>
        </article>
      );
    })}

  </div>

</section>

</BaseLayout>
