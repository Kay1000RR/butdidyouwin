---
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = [
  {
    slug: '5-signs-fresh-eyes-needed',
    title: '5 Signs Your Paid Media Accounts Need a Fresh Set of Eyes',
    date: '2025-01-15',
    description: 'Even well-managed paid media accounts accumulate inefficiencies over time. Here are five symptoms that suggest it\'s time for an independent evaluation.',
    readTime: '6 min read',
  },
  {
    slug: 'cost-of-wasted-ad-spend',
    title: 'Common Optimization Opportunities in Mature Paid Media Accounts',
    date: '2025-01-10',
    description: 'The hidden cost of wasted ad spend and common inefficiencies found in mature advertising accounts.',
    readTime: '8 min read',
  },
  {
    slug: 'percentage-pricing-conflicts',
    title: 'How Pricing Models Shape Paid Media Recommendations',
    date: '2025-01-05',
    description: 'Understanding how percentage-of-spend pricing creates conflicts of interest in paid media management.',
    readTime: '7 min read',
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "BUT DID YOU WIN Blog",
  "description": "Insights on paid media diagnosis, advertising efficiency, and business outcomes from an independent auditor.",
  "url": "https://butdidyouwin.com/blog",
  "publisher": {
    "@type": "Organization",
    "name": "BUT DID YOU WIN"
  },
  "blogPost": posts.map(post => ({
    "@type": "BlogPosting",
    "headline": post.title,
    "description": post.description,
    "datePublished": post.date,
    "url": `https://butdidyouwin.com/blog/${post.slug}`
  }))
};
---

<BaseLayout 
  title="Blog | BUT DID YOU WIN - Paid Media Insights"
  description="Insights on paid media diagnosis, advertising efficiency, and business outcomes from an independent auditor. Perspectives on the gap between dashboard metrics and reality."
  schema={schema}
>
  <section class="py-10 md:py-16 bg-white">
    <div class="site-container">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-center mb-4 md:mb-6 text-brand-blue">Blog</h1>
        <p class="text-lg md:text-xl text-center text-gray-700 mb-8 md:mb-12 leading-relaxed">
          Perspectives on paid media, business outcomes, and the gap between dashboard metrics and reality.
        </p>

        <div class="space-y-6 md:space-y-8">
          {posts.map((post) => (
            <article class="card">
              <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-gray-600 mb-3">
                <time datetime={post.date}>
                  {new Date(post.date).toLocaleDateString('en-US', { 
                    year: 'numeric', 
                    month: 'long', 
                    day: 'numeric' 
                  })}
                </time>
                <span aria-hidden="true">·</span>
                <span>{post.readTime}</span>
              </div>
              <h2 class="text-xl md:text-2xl font-bold mb-2 md:mb-3 text-brand-blue">
                <a href={`/blog/${post.slug}`} class="hover:underline">{post.title}</a>
              </h2>
              <p class="text-gray-700 mb-4 leading-relaxed">{post.description}</p>
              <a href={`/blog/${post.slug}`} class="text-brand-blue font-semibold hover:underline">
                Read more →
              </a>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-10 md:py-16 bg-gray-50">
    <div class="site-container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="mb-4 md:mb-6 text-brand-blue">Ready for an Independent Diagnosis?</h2>
        <p class="text-base md:text-lg text-gray-700 mb-6 md:mb-8">
          Stop wondering if your paid media is actually working. Get a definitive answer.
        </p>
        <a href="/contact" class="btn-primary">Request Diagnosis</a>
      </div>
    </div>
  </section>
</BaseLayout>
