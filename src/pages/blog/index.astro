---
import BaseLayout from '../../layouts/BaseLayout.astro';

const blogPosts = [
  {
    title: "5 Signs Your Paid Media Accounts Need a Fresh Set of Eyes",
    slug: "5-signs-fresh-eyes-needed",
    excerpt: "Even well-managed paid media accounts accumulate inefficiencies over time. Here are five symptoms that suggest it's time for an independent evaluation.",
    date: "2025-01-15",
    author: "Kay Inoue",
    readTime: "6 min read"
  },
  {
    title: "How Pricing Models Shape Paid Media Recommendations",
    slug: "percentage-pricing-conflicts",
    excerpt: "Understanding how different pricing structures create different incentives in paid media management. Not about ethics. Just about math.",
    date: "2025-01-10",
    author: "Kay Inoue",
    readTime: "7 min read"
  },
  {
    title: "Common Optimization Opportunities in Mature Paid Media Accounts",
    slug: "cost-of-wasted-ad-spend",
    excerpt: "A Las Vegas case study showing how even well-managed accounts accumulate inefficiencies over time. Real numbers, real opportunities.",
    date: "2025-01-05",
    author: "Kay Inoue",
    readTime: "10 min read"
  }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "BUT DID YOU WIN Blog",
  "description": "Insights on paid media audits, optimization strategies, and independent evaluation of Google Ads and Meta Ads performance.",
  "blogPost": blogPosts.map(post => ({
    "@type": "BlogPosting",
    "headline": post.title,
    "datePublished": post.date,
    "author": {
      "@type": "Person",
      "name": post.author
    },
    "description": post.excerpt
  }))
};
---

<BaseLayout 
  title="Blog | BUT DID YOU WIN - Paid Media Insights & Case Studies"
  description="Insights on paid media audits, optimization strategies, and independent evaluation. Real case studies, real numbers, real opportunities."
  schema={schema}
>
  <section class="py-16 bg-white">
    <div class="site-container">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-center mb-6 text-brand-blue">Blog</h1>
        <p class="text-xl text-center text-gray-700 mb-12 leading-relaxed">
          Insights on paid media audits, optimization strategies, and independent evaluation.
        </p>

        <div class="space-y-8">
          {blogPosts.map(post => (
            <article class="card">
              <div class="flex items-center gap-4 text-sm text-gray-600 mb-3">
                <time datetime={post.date}>
                  {new Date(post.date).toLocaleDateString('en-US', { 
                    year: 'numeric', 
                    month: 'long', 
                    day: 'numeric' 
                  })}
                </time>
                <span>•</span>
                <span>{post.readTime}</span>
              </div>
              <h2 class="text-2xl font-bold mb-3 text-brand-blue">
                <a href={`/blog/${post.slug}`} class="hover:underline">
                  {post.title}
                </a>
              </h2>
              <p class="text-gray-700 mb-4 leading-relaxed">
                {post.excerpt}
              </p>
              <a 
                href={`/blog/${post.slug}`} 
                class="text-brand-blue font-semibold hover:underline inline-flex items-center"
              >
                Read more →
              </a>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="site-container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="mb-6 text-brand-blue">Ready for an Independent Audit?</h2>
        <p class="text-lg text-gray-700 mb-8">
          Stop wondering if your paid media is working. Get a forensic audit with waste quantified in dollars.
        </p>
        <a href="/contact" class="btn-primary inline-block">Request Your Audit</a>
      </div>
    </div>
  </section>
</BaseLayout>
