---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const published = posts.filter((p) => p.data.draft !== true);

  return published.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const author = post.data.author ?? "Kay Inoue";

const publishedDate = new Date(post.data.pubDate);

const formattedDate = publishedDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

// Simple read time (200 words/min)
const words =
  post.body?.split(/\s+/g).length ?? 0;

const readTime = Math.max(1, Math.ceil(words / 200));


const canonical =
  post.data.canonical ??
  `https://butdidyouwin.com/blog/${post.slug}`;
---

<BaseLayout
  title={`${post.data.title} | BUT DID YOU WIN`}
  description={post.data.description}
>
  <article class="site-container py-16">
    <div class="mx-auto max-w-[720px]">

      <header class="mb-12">

        <h1 class="text-3xl md:text-4xl font-semibold leading-tight text-gray-900">
          {post.data.title}
        </h1>

        {post.data.description && (
          <p class="mt-5 text-lg leading-relaxed text-gray-700">
            {post.data.description}
          </p>
        )}

        <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-gray-500">
          <span class="font-medium text-gray-700">
            {author}
          </span>

          <span aria-hidden="true">•</span>

          <time datetime={post.data.pubDate}>
            {formattedDate}
          </time>

          <span aria-hidden="true">•</span>

          <span>
            {readTime} min read
          </span>
        </div>

      </header>

      <div class="article-prose">
  <Content />
</div>

<!-- Article CTA -->
<section class="mx-auto mt-16 max-w-[720px]">
  <div class="rounded-xl border border-gray-200 bg-white p-8">

    <h2 class="text-xl font-semibold text-gray-900">
      Get an independent paid media verdict
    </h2>

    <p class="mt-4 text-gray-700">
      I evaluate whether your paid media is producing real business outcomes, not prettier dashboards.
    </p>

    <p class="mt-3 text-gray-700">
      This diagnostic determines whether revenue impact, sales behavior, attribution integrity, and capital
      allocation discipline actually hold up under scrutiny.
    </p>

    <p class="mt-3 text-gray-700">
      No agency pitch. No optimization retainer.
    </p>

    <p class="mt-3 text-gray-700">
      Just an independent decision-grade assessment.
    </p>

    <a
      href="/contact"
      class="mt-6 inline-block rounded-md bg-brand-blue px-6 py-3 font-medium text-white hover:opacity-90"
    >
      Request a diagnostic
    </a>

  </div>

  <div class="mt-8">
    <a href="/blog" class="text-sm font-medium text-brand-blue hover:underline">
      ← Back to Blog
    </a>
  </div>
</section>

  </article>
</BaseLayout>

